import &StandardImport

each [input, output] in []
    0     0_B
    10    10_B
    1023  1023_B
    10240   10.00kB
    1024**1 1.00kB
    1024**2 1.00mB
    1024**3 1.00gB
    1024**4 1.00tB
    1024**5 1.00pB
    1024**6 1.00eB

    1024**1 - 1   1023_B
    1024**2 - 1   1024.00kB
    1024**3 - 1   1024.00mB
    1024**4 - 1   1024.00gB
    1024**5 - 1   1024.00tB
    1024**6 - 100 1024.00pB

  test "humanByteSize #{input} >> #{output}" ->
    assert.eq
      humanByteSize input
      output

each [output, args...] in []
    [] :s3://my-bucket/my-key :my-bucket undefined :my-key
    [] :my-folder/my-key :my-bucket :my-folder :my-key
    [] :my-folder/my-key undefined :my-folder :my-key

  test "createS3Url #{args.join ', '} >> #{output}" ->
    assert.eq
      createS3Url args...
      output

each [input, bucket, prefix, region, folder] in []
    [] :s3://mybucket/prefix/key.txt                               :mybucket :prefix/key.txt undefined     undefined
    [] :s3://mybucket/                                             :mybucket ''               undefined     undefined
    [] :s3://mybucket                                              :mybucket ''               undefined     undefined
    [] :https://mybucket.s3.amazonaws.com/prefix/key               :mybucket :prefix/key      undefined     undefined
    [] :https://mybucket.s3-us-west-2.amazonaws.com/prefix/key     :mybucket :prefix/key      :us-west-2 undefined
    [] :https://s3-us-west-2.amazonaws.com/mybucket/prefix/key     :mybucket :prefix/key      :us-west-2 undefined
    [] :my/local/path                                              undefined      undefined             undefined     :my/local/path

  test "parseS3Url #{input}" ->
    result = parseS3Url input
    assert.eq result.bucket,  bucket
    assert.eq result.prefix,  prefix
    assert.eq result.region,  region
    assert.eq result.folder,  folder

test "processArgsIntoOptions with s3 src and local dst" ->
  result = processArgsIntoOptions [] :s3://src-bucket/prefix :local/folder
  assert.eq result.bucket,   :src-bucket
  assert.eq result.prefix,   :prefix
  assert.eq result.tofolder, :local/folder

test "parseS3Url with non-string returns empty" ->
  assert.eq parseS3Url(undefined),      {}
  assert.eq parseS3Url(undefined), {}
  assert.eq parseS3Url(42),        {}

test "shellExec pwd" ->
  shellExec "pwd"
  .then (out) ->
    assert.match out, "\/s3p"