import &StandardImport, &@aws-sdk/client-s3

endpoint    = process.env.S3_ENDPOINT
testBucket  = :s3p-test

s3Client =
  if endpoint
    new S3Client {}
      region:         :us-east-1
      endpoint
      forcePathStyle: true
      credentials:
        accessKeyId:      process.env.AWS_ACCESS_KEY_ID     ? :testAccessKey
        secretAccessKey:  process.env.AWS_SECRET_ACCESS_KEY  ? :testSecretKey

## putTestObjects
  IN: objects: array of {Key, Body} or just strings (used as both Key and Body)
  OUT: Promise
putTestObjects = (objects) ->
  Promise.all array obj in-array objects
    {Key, Body} = if obj is String then Key: obj, Body: obj else obj
    s3Client.send new PutObjectCommand
      Bucket: testBucket
      Key:    Key
      Body:   Body

## deleteTestObjects
  IN: keys: array of strings
  OUT: Promise
deleteTestObjects = (keys) ->
  Promise.all array Key in-array keys
    s3Client.send new DeleteObjectCommand
      Bucket: testBucket
      Key:    Key

## setupTestScenario
  Sets up a describe block with beforeAll/afterAll that creates and cleans up test objects.
  IN:
    name: string - describe block name
    keys: array of strings - keys to create (body = key string)
    fn: (testOptions) -> define tests inside this function
  testOptions: {endpoint, testBucket}
setupTestScenario = (name, keys, fn) ->
  if endpoint
    describe name, ->
      beforeAll -> putTestObjects keys
      afterAll  -> deleteTestObjects keys
      fn {} endpoint, testBucket
  else
    test "#{name} skipped (no S3_ENDPOINT)" ->

{}
  endpoint
  testBucket
  s3Client
  putTestObjects
  deleteTestObjects
  setupTestScenario
